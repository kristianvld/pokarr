{
  "name": "pokarr",
  "private": true,
  "version": "0.1.2",
  "license": "Apache-2.0",
  "homepage": "https://github.com/kristianvld/pokarr",
  "repository": {
    "type": "git",
    "url": "https://github.com/kristianvld/pokarr.git"
  },
  "bugs": {
    "url": "https://github.com/kristianvld/pokarr/issues"
  },
  "engines": {
    "bun": ">=1.3.10"
  },
  "type": "module",
  "packageManager": "bun@1.3.10",
  "scripts": {
    "dev": "bun --watch server.ts",
    "dev:server": "bun --watch server.ts",
    "doctor": "react-doctor . --yes --verbose",
    "doctor:score": "react-doctor . --yes --score",
    "lint": "eslint . --max-warnings 0",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.client.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "build": "bun run scripts/build-app.ts",
    "start": "bun run scripts/start-built.ts",
    "check": "bun run lint && bun test && bun run typecheck && bun run build && vitepress build docs",
    "smoke:built": "bun run scripts/smoke-built-ui.ts",
    "check:prod": "bun run check && bun run smoke:built",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "docs:snapshot": "bun run scripts/snapshot-docs.ts"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-query-devtools": "^5.91.3",
    "zod": "^4.0.17"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-switch": "^1.2.6",
    "@types/bun": "^1.2.18",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "bun-plugin-tailwind": "0.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "eslint": "^9.0.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.0",
    "globals": "^16.0.0",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-doctor": "0.0.30",
    "react-dom": "^19.1.0",
    "playwright": "^1.55.0",
    "tailwind-merge": "^3.3.0",
    "tailwindcss": "^4.1.10",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.0.0",
    "vitepress": "^1.6.4"
  }
}
