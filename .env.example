# Server
PORT=3000
POKARR_DATA_DIR=./data
TZ=UTC
# Application settings such as backup retention, backup schedule, and notifications
# are configured in the UI and stored in the SQLite database.
POKARR_SESSION_TTL_DAYS=30
# auto, true, or false. auto sets Secure cookies when the request is served over HTTPS.
POKARR_COOKIE_SECURE=auto
# Optional override for the session cookie name.
# POKARR_SESSION_COOKIE_NAME=pokarr_session

# Arr request and recovery behavior
POKARR_ARR_REQUEST_TIMEOUT_MS=15000
POKARR_INSTANCE_RECOVERY_MS=60000
POKARR_INSTANCE_HEALTH_POLL_MS=60000
POKARR_SCHEDULER_POLL_MS=30000

# Scan worker behavior
POKARR_SCAN_CATALOG_INTERVAL_MS=900000
POKARR_SCAN_DETAIL_REFRESH_MS=7200000
POKARR_SCAN_DETAIL_HARD_MAX_AGE_MS=86400000
POKARR_SCAN_CATALOG_HARD_MAX_AGE_MS=7200000
POKARR_SCAN_SCHEDULER_POLL_MS=60000
POKARR_SCAN_DETAIL_BATCH_SIZE=30
POKARR_SCAN_DETAIL_CONCURRENCY=6

# Restore safety
POKARR_RESTORE_IDLE_TIMEOUT_MS=30000
